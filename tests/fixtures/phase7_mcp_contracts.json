  "prompt_analyze_bundle_with_phase7": {
    "description": "Guide an agent through running the local Phase 7 analyzer against a portable session/case bundle and persisting findings.",
    "prompt": "analyze_bundle_with_phase7",
    "message_count": 1,
    "first_role": "user",
    "text": "Run `tapescript_analyzer_run` against `/tmp/example-case-bundle.msgpack` using `case_bundle_path`. Then call `tapescript_findings_list` on the returned `analysis_artifact_id`, reopen the durable analysis resource with `resources/read` on `tape://phase7/analysis/<analysis_artifact_id>`, and if follow-up planning is needed call `tapescript_playbook_apply` in `dry_run` mode. Return: analyzer profile, durable artifact ids, ranked findings, replay context, and the best next investigation actions."
  },
  "prompt_review_phase7_findings": {
    "description": "Guide an agent through reopening a stored Phase 7 analysis artifact, summarizing findings, and planning follow-up actions.",
    "prompt": "review_phase7_findings",
    "message_count": 1,
    "first_role": "user",
    "text": "Review stored Phase 7 analysis artifact `phase7-analysis-1234abcd`. Start with `tapescript_findings_list`, then reopen the persisted JSON and markdown resources with `resources/read` on `tape://phase7/analysis/phase7-analysis-1234abcd` and `tape://phase7/analysis/phase7-analysis-1234abcd/markdown`. If the findings warrant action planning, call `tapescript_playbook_apply` in `dry_run` mode. Return: top findings, confidence, replay context, and recommended next tools."
  },
  "prompt_review_phase7_playbook": {
    "description": "Guide an agent through reopening a stored Phase 7 playbook artifact and converting it into an investigation plan.",
    "prompt": "review_phase7_playbook",
    "message_count": 1,
    "first_role": "user",
    "text": "Review stored Phase 7 playbook artifact `phase7-playbook-1234abcd`. Reopen it with `resources/read` on `tape://phase7/playbook/phase7-playbook-1234abcd` and `tape://phase7/playbook/phase7-playbook-1234abcd/markdown`, then follow the referenced analysis artifact back through `tapescript_findings_list`. Return: action order, affected findings, suggested tools, and whether any step still needs manual confirmation."
  },
